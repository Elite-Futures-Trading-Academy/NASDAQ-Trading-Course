<div id="course-container" style="font-family: Arial; color: #fff; background:#0b0b0b; padding:20px;">

  <h1 style="color:#d4af37;">Futures Trading Foundations</h1>
  <p style="color:#ccc;">Educate – Execute – Elevate</p>

  <div id="modules"></div>

</div>

<script>
const courseData = [
  {
    title: "Module 1 — Market Foundations (Educate)",
    lessons: [
      "What the Futures Market Actually Is",
      "How Price Moves",
      "Market Sessions & Volatility"
    ]
  },
  {
    title: "Module 2 — Chart Reading & Structure",
    lessons: [
      "Candlesticks That Actually Matter",
      "Market Structure",
      "Support & Resistance That Works"
    ]
  },
  {
    title: "Module 3 — Strategy Building",
    lessons: [
      "Your Trading Setup Framework",
      "Risk Management (Survival Rule)",
      "Entry, Stop, Take Profit Logic"
    ]
  },
  {
    title: "Module 4 — Execution & Psychology",
    lessons: [
      "Execution Discipline",
      "Emotional Control",
      "Building Consistency"
    ]
  },
  {
    title: "Module 5 — Professional Development",
    lessons: [
      "Building a Trading Plan",
      "Performance Review System",
      "Graduation & Next Steps"
    ]
  }
];

const container = document.getElementById("modules");

courseData.forEach((module, index) => {
  const moduleDiv = document.createElement("div");

  moduleDiv.style = `
    margin-bottom:20px;
    padding:15px;
    border:1px solid #333;
    border-radius:10px;
    background:#111;
  `;

  let lessonsHTML = "";

  module.lessons.forEach((lesson, i) => {
    lessonsHTML += `
      <div style="padding:8px; margin:5px 0; background:#1a1a1a; border-left:3px solid #d4af37;">
        <input type="checkbox" class="lesson-check" data-module="${index}" data-lesson="${i}">
        <span style="margin-left:10px;">${lesson}</span>
      </div>
    `;
  });

  moduleDiv.innerHTML = `
    <h2 style="color:#d4af37;">${module.title}</h2>
    ${lessonsHTML}
  `;

  container.appendChild(moduleDiv);
});

// Simple progress tracker (local only)
document.addEventListener("change", function(e) {
  if (e.target.classList.contains("lesson-check")) {
    const all = document.querySelectorAll(".lesson-check").length;
    const checked = document.querySelectorAll(".lesson-check:checked").length;

    let progress = Math.round((checked / all) * 100);

    console.log("Progress: " + progress + "%");
  }
});
</script>
