<div style="font-family:Arial; background:#0b0b0b; color:#fff; padding:20px;">
  <h1 style="color:#d4af37;">Futures Trading Foundations</h1>
  <p>Educate – Execute – Elevate</p>

  <div id="course"></div>
  <div style="margin-top:20px; color:#d4af37;" id="progressText"></div>
</div>

<script>
const courseData = [
  {
    id: "m1",
    title: "Market Foundations",
    lessons: [
      { id: "l1", title: "What the Futures Market Actually Is" },
      { id: "l2", title: "How Price Moves" },
      { id: "l3", title: "Market Sessions & Volatility" }
    ]
  },
  {
    id: "m2",
    title: "Chart Reading & Structure",
    lessons: [
      { id: "l4", title: "Candlesticks That Matter" },
      { id: "l5", title: "Market Structure" },
      { id: "l6", title: "Support & Resistance" }
    ]
  }
];

// Load saved progress
let progress = JSON.parse(localStorage.getItem("courseProgress")) || {};

function saveProgress() {
  localStorage.setItem("courseProgress", JSON.stringify(progress));
}

function render() {
  const container = document.getElementById("course");
  container.innerHTML = "";

  courseData.forEach(module => {
    const div = document.createElement("div");
    div.style = "margin-bottom:20px; padding:10px; border:1px solid #333; border-radius:8px;";

    let html = `<h2 style='color:#d4af37;'>${module.title}</h2>`;

    module.lessons.forEach(lesson => {
      const checked = progress[lesson.id] ? "checked" : "";

      html += `
        <div style="margin:5px 0;">
          <label>
            <input type="checkbox" data-id="${lesson.id}" ${checked}>
            ${lesson.title}
          </label>
        </div>
      `;
    });

    div.innerHTML = html;
    container.appendChild(div);
  });

  document.querySelectorAll("input[type=checkbox]").forEach(cb => {
    cb.addEventListener("change", (e) => {
      progress[e.target.dataset.id] = e.target.checked;
      saveProgress();
      updateProgress();
    });
  });

  updateProgress();
}

function updateProgress() {
  const total = Object.keys(progress).length;
  const completed = Object.values(progress).filter(v => v).length;

  const percent = total ? Math.round((completed / 6) * 100) : 0;

  document.getElementById("progressText").innerText =
    "Progress: " + percent + "%";
}

render();
</script>
