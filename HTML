<div id="course"></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import {
  getFirestore,
  doc,
  getDoc,
  setDoc,
  updateDoc
} from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

/* 🔥 YOUR FIREBASE CONFIG */
const firebaseConfig = {
  apiKey: "YOUR_API_KEY",
  authDomain: "YOUR_PROJECT.firebaseapp.com",
  projectId: "YOUR_PROJECT_ID",
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

/* COURSE STRUCTURE */
const courseId = "futures-foundations";

const courseData = [
  {
    id: "m1",
    title: "Market Foundations",
    lessons: [
      { id: "m1l1", title: "What the Futures Market Actually Is" },
      { id: "m1l2", title: "How Price Moves" },
      { id: "m1l3", title: "Market Sessions & Volatility" }
    ]
  },
  {
    id: "m2",
    title: "Chart Reading & Structure",
    lessons: [
      { id: "m2l1", title: "Candlesticks That Matter" },
      { id: "m2l2", title: "Market Structure" },
      { id: "m2l3", title: "Support & Resistance" }
    ]
  }
];

/* 🔐 LOAD USER PROGRESS */
async function loadUser(userId) {
  const ref = doc(db, "users", userId);
  const snap = await getDoc(ref);

  if (!snap.exists()) {
    await setDoc(ref, {
      userId,
      progress: {},
      completedLessons: 0,
      courseProgressPercent: 0,
      certificateUnlocked: false
    });
    return {};
  }

  return snap.data().progress || {};
}

/* ✅ SAVE PROGRESS */
async function toggleLesson(userId, lessonId, isChecked) {
  const ref = doc(db, "users", userId);
  const snap = await getDoc(ref);
  const data = snap.data();

  let progress = data.progress || {};
  progress[lessonId] = isChecked;

  const completedLessons = Object.values(progress).filter(v => v).length;
  const totalLessons = 6; // update dynamically later
  const percent = Math.round((completedLessons / totalLessons) * 100);

  await updateDoc(ref, {
    progress,
    completedLessons,
    courseProgressPercent: percent,
    certificateUnlocked: percent === 100
  });
}

/* 🧠 RENDER COURSE */
async function render(userId) {
  const progress = await loadUser(userId);

  const container = document.getElementById("course");

  courseData.forEach(module => {
    const moduleDiv = document.createElement("div");

    let html = `<h2>${module.title}</h2>`;

    module.lessons.forEach(lesson => {
      const checked = progress[lesson.id] ? "checked" : "";

      html += `
        <div>
          <label>
            <input type="checkbox" data-id="${lesson.id}" ${checked}>
            ${lesson.title}
          </label>
        </div>
      `;
    });

    moduleDiv.innerHTML = html;
    container.appendChild(moduleDiv);
  });

  document.querySelectorAll("input[type=checkbox]").forEach(cb => {
    cb.addEventListener("change", e => {
      toggleLesson(userId, e.target.dataset.id, e.target.checked);
    });
  });
}

/* 🚀 TEMP USER (replace with real auth later) */
const demoUser = "user_001";
render(demoUser);
</script>
